{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "lib": ["ESNext", "DOM"],
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "isolatedModules": true,
    "skipLibCheck": true,
    "outDir": "www"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
